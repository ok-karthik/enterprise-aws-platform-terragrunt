{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    "group:monorepos",
    "group:recommended"
  ],
  "description": "Enterprise-grade Renovate config for Terragrunt/Terraform infrastructure",
  "dependencyDashboard": true,
  "prCreation": "not-pending",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track tool versions in GitHub Actions inputs",
      "fileMatch": ["^\\.github/actions/.+/action\\.yml$"],
      "matchStrings": [
        "default: '(?<currentValue>[^']*)'\\s+# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?"
      ]
    },
    {
      "customType": "regex",
      "description": "Track tool versions in Dockerfile ARGs",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG\\s+(?:.*?)_VERSION=(?<currentValue>.*)\\s+# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?"
      ]
    },
    {
      "customType": "regex",
      "description": "Track Terragrunt registry modules (tfr:// protocol)",
      "fileMatch": ["\\.hcl$"],
      "matchStrings": [
        "source\\s*=\\s*\"tfr://registry\\.terraform\\.io/(?<depName>[^\\?]+)(?://.*?)?\\?version=(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "terraform-module"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["terraform", "terragrunt", "custom.regex"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Infrastructure Dependencies (Non-Major)"
    },
    {
      "matchPackageNames": ["terraform-aws-modules/**"],
      "groupName": "AWS Official Modules"
    },
    {
      "matchPackageNames": ["hashicorp/terraform", "gruntwork-io/terragrunt"],
      "groupName": "Core IaC Tools"
    }
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["at any time"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0
}
